# Copiar para `.env` e preencher. NUNCA commitar o .env real.

# --- Django ---
# Em produção gerar uma chave nova: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=troque-esta-chave-em-producao
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Modo de arranque: ERP (Hospitality ERP, default) ou PCC (Platform Control Center)
SYSTEM_MODE=ERP

# --- PRODUÇÃO (definir apenas no servidor; deixar em branco/omisso em dev) ---
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=erp.hotelx.ao,192.168.1.10
# DJANGO_CORS_ORIGINS=https://erp.hotelx.ao
# DJANGO_SSL_REDIRECT=True
# DJANGO_STATIC_ROOT=/var/erp/staticfiles

# --- Base de dados (PostgreSQL em produção; SQLite se DB_ENGINE omisso) ---
# DB_ENGINE=postgresql
# DB_NAME=erp_2026
# DB_USER=erp
# DB_PASSWORD=senha-forte-da-bd
# DB_HOST=localhost
# DB_PORT=5432

# --- Email (SendGrid) ---
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@topconsultores.com
